# Sample configuration for the Flask webhook receiver.
# Copy to `.env`, adjust values, and load before running:
#   export $(grep -v '^#' .env | xargs)
#   python app.py
#
# These secrets must exactly match the Secret values configured for the
# same channel in the Go OTP service's .env (OTP_WEBHOOK_SMS_SECRET,
# OTP_WEBHOOK_EMAIL_SECRET) — that's what lets this server verify the
# signature on incoming requests.

OTP_WEBHOOK_SMS_SECRET=dev-only-sms-secret-32-bytes!!!
OTP_WEBHOOK_EMAIL_SECRET=dev-only-email-secret-32-bytes!!

PORT=5001
