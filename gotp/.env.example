# Sample configuration for the Go OTP service.
# Copy to `.env`, adjust values, and load before running (see README).
#
# NEVER commit real secrets. These are placeholder dev values only —
# generate real ones with e.g.: openssl rand -base64 32

# Redis connection
REDIS_ADDR=localhost:6379

# Server-side pepper used to HMAC the OTP codes before storing in Redis.
# At least 32 random bytes. Rotating this invalidates any in-flight OTPs
# (harmless given the short TTL).
OTP_HMAC_SECRET=change-me-to-a-random-32-byte-value

# Webhook endpoints, one per delivery channel. URL is where the Go service
# POSTs the signed OTP payload; Secret must exactly match the secret the
# receiving webhook server uses to verify the signature (see the Flask
# server's own .env.example).
OTP_WEBHOOK_SMS_URL=http://localhost:5001/hooks/sms-otp
OTP_WEBHOOK_SMS_SECRET=dev-only-sms-secret-32-bytes!!!

OTP_WEBHOOK_EMAIL_URL=http://localhost:5001/hooks/email-otp
OTP_WEBHOOK_EMAIL_SECRET=dev-only-email-secret-32-bytes!!

# HTTP server port (Echo)
PORT=8080
